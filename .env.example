# =============================================================================
# VoiceClinicAgent Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Server Configuration (ALWAYS REQUIRED)
# -----------------------------------------------------------------------------
ENV_BASE_URL=http://localhost:7860

# -----------------------------------------------------------------------------
# LLM API Configuration (ONLY for LLM-based agents)
# -----------------------------------------------------------------------------
# Using Hugging Face Inference API (Free Tier: 1000 requests/month)

# API_BASE_URL: Hugging Face model endpoint
API_BASE_URL=https://router.huggingface.co/models/meta-llama/Meta-Llama-3-8B-Instruct

# MODEL_NAME: The model identifier
MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# HF_TOKEN: Your Hugging Face token (starts with hf_...)
# Get it from: https://huggingface.co/settings/tokens
# IMPORTANT: Replace this placeholder with your actual token!
HF_TOKEN=your_hf_token_here

# -----------------------------------------------------------------------------
# Notes:
# -----------------------------------------------------------------------------
# 1. ENV_BASE_URL points to your LOCAL environment server (app.py on port 7860)
# 2. API_BASE_URL points to the Hugging Face model endpoint
# 3. Replace your_hf_token_here with your actual HF token
# 4. Free tier: 1000 requests/month, ~10 requests/minute
# 5. Model may take 20-30 seconds to "warm up" on first use
